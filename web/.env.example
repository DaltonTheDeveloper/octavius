# ─── Local dev ──────────────────────────────────────────────
# SQLite file kept out of git (see .gitignore). Seed with:
#   npx prisma db push && npx prisma db seed
DATABASE_URL="file:./dev.db"

# ─── Auth.js (optional in dev — omit to skip login UI) ──────
# Generate:  openssl rand -base64 32
AUTH_SECRET=""

# GitHub OAuth app: https://github.com/settings/applications/new
# Homepage:       https://getoctavius.vercel.app
# Callback URL:   https://getoctavius.vercel.app/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ─── Production swap ────────────────────────────────────────
# DATABASE_URL="postgresql://... (from Neon/Supabase/Vercel Postgres)"
# For prod, also set `provider = "postgresql"` in prisma/schema.prisma.
